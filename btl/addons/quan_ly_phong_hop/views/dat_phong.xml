<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_dat_phong_form" model="ir.ui.view">
            <field name="name">dat_phong.form</field>
            <field name="model">dat_phong</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_duyet" string="Duyệt" type="object" class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                        <button name="action_bat_dau" string="Bắt đầu sử dụng" type="object" class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'da_duyet')]}"/>
                        <button name="action_hoan_thanh" string="Hoàn thành" type="object" class="btn-success" attrs="{'invisible': [('trang_thai', '!=', 'dang_su_dung')]}"/>
                        <button name="action_huy" string="Hủy" type="object" class="btn-danger" attrs="{'invisible': [('trang_thai', 'in', ['hoan_thanh', 'huy'])]}"/>
                        <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,da_duyet,dang_su_dung,hoan_thanh"/>
                    </header>
                    <sheet>
                        <div class="alert alert-warning" role="alert" attrs="{'invisible': [('canh_bao_suc_chua', '=', '')]}">
                            <field name="canh_bao_suc_chua" nolabel="1"/>
                        </div>
                        <group>
                            <group string="Thông tin đặt phòng">
                                <field name="phong_hop_id"/>
                                <field name="nhan_vien_id"/>
                                <field name="so_nguoi"/>
                                <field name="muc_dich"/>
                            </group>
                            <group string="Thời gian">
                                <field name="thoi_gian_bat_dau"/>
                                <field name="thoi_gian_ket_thuc"/>
                            </group>
                        </group>
                        <field name="ghi_chu" placeholder="Ghi chú thêm..."/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_dat_phong_tree" model="ir.ui.view">
            <field name="name">dat_phong.tree</field>
            <field name="model">dat_phong</field>
            <field name="arch" type="xml">
                <tree decoration-success="trang_thai == 'hoan_thanh'" decoration-info="trang_thai == 'dang_su_dung'" decoration-muted="trang_thai == 'huy'">
                    <field name="phong_hop_id"/>
                    <field name="nhan_vien_id"/>
                    <field name="thoi_gian_bat_dau"/>
                    <field name="thoi_gian_ket_thuc"/>
                    <field name="so_nguoi"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record id="view_dat_phong_calendar" model="ir.ui.view">
            <field name="name">dat_phong.calendar</field>
            <field name="model">dat_phong</field>
            <field name="arch" type="xml">
                <calendar date_start="thoi_gian_bat_dau" date_stop="thoi_gian_ket_thuc" color="phong_hop_id" event_open_popup="true">
                    <field name="phong_hop_id"/>
                    <field name="nhan_vien_id"/>
                    <field name="so_nguoi"/>
                </calendar>
            </field>
        </record>

        <record id="action_dat_phong" model="ir.actions.act_window">
            <field name="name">Đặt phòng</field>
            <field name="res_model">dat_phong</field>
            <field name="view_mode">tree,form,calendar</field>
        </record>
    </data>
</odoo>
